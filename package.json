{
  "name": "devil-may-type",
  "displayName": "Devil May Type",
  "description": "Style combo rating for your coding sessions",
  "version": "0.0.1",
  "publisher": "Soooda",
  "engines": {
    "vscode": "^1.80.0"
  },
  "pricing": "Free",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Soooda/devil-may-type"
  },
  "icon": "./assets/icon.png",
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dmt.reset",
        "title": "Devil May Type: Reset Rank"
      },
      {
        "command": "dmt.showPanel",
        "title": "Devil May Type: Show Animation Panel"
      }
    ],
    "configuration": {
      "title": "Devil May Type",
      "properties": {
        "dmt.decayRate": {
          "type": "number",
          "default": 0.015,
          "description": "Decay rate multiplier (higher = faster decay)",
          "minimum": 0.001,
          "maximum": 0.1
        },
        "dmt.comboWindow": {
          "type": "number",
          "default": 200,
          "description": "Milliseconds between keypresses to count as a combo",
          "minimum": 50,
          "maximum": 1000
        },
        "dmt.pasteThreshold": {
          "type": "number",
          "default": 50,
          "description": "Character count above which a single change is treated as a paste (not awarded full points)",
          "minimum": 1
        },
        "dmt.gracePeriod": {
          "type": "number",
          "default": 1500,
          "description": "Milliseconds of inactivity before decay begins",
          "minimum": 0
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.mjs --production",
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.0",
    "typescript": "^5.4.0"
  }
}
